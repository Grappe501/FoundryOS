{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "@foundry/core": ["./packages/core/src"],
      "@foundry/ui": ["./packages/ui/src"],
      "@foundry/self-build": ["./packages/self-build/src"]
    }
  },
  "exclude": ["node_modules", ".cache", "dist"]
}
