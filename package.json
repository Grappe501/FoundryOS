{
  "name": "foundryos",
  "version": "0.0.1",
  "private": true,
  "description": "FoundryOS — AI Operating System for 1000 Specialty Apps",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "foundry": {
    "version": "0.8.0-path-engine",
    "current_pass": "PASS-040C",
    "next_pass": "PASS-040E",
    "vision": "Foundry helps people become who they are capable of becoming."
  },
  "scripts": {
    "setup": "powershell -ExecutionPolicy Bypass -File ./scripts/setup-h-drive.ps1",
    "enforce": "node scripts/enforce-h-drive.js",
    "cleanup:c": "powershell -ExecutionPolicy Bypass -File ./scripts/cleanup-c-drive-foundry.ps1",
    "migrate:c-to-h": "powershell -ExecutionPolicy Bypass -File ./scripts/full-c-drive-migration.ps1",
    "sweep:c-drive": "powershell -ExecutionPolicy Bypass -File ./scripts/full-c-sweep.ps1",
    "cleanup:c-emergency": "powershell -ExecutionPolicy Bypass -File ./scripts/emergency-c-cleanup.ps1",
    "verify:c-clean": "powershell -ExecutionPolicy Bypass -File ./scripts/verify-c-drive-clean.ps1",
    "preflight": "node scripts/enforce-h-drive.js && node scripts/preflight.js",
    "sandbox": "node scripts/sandbox-netlify.js",
    "build:platform": "npm run build -w @foundry/platform",
    "build:topic": "node scripts/build-topic.js",
    "build:world": "node scripts/build-world.js",
    "build:marketing": "node scripts/build-marketing.js",
    "audit:audience": "npx tsx scripts/audit-audience-language.ts",
    "audit:worlds": "npx tsx packages/world-factory/cli/audit.ts",
    "audit:marketing": "npx tsx packages/marketing-factory/cli/audit.ts",
    "audit:depth": "npx tsx scripts/audit-world-depth.ts",
    "audit:experience": "npx tsx scripts/audit-world-experience.ts",
    "audit:copy-depth": "npx tsx scripts/audit-copy-depth.ts",
    "audit:atlas": "npx tsx scripts/audit-atlas.ts",
    "audit:events": "npx tsx scripts/audit-events.ts",
    "audit:identity": "npx tsx scripts/audit-identity.ts",
    "audit:continuity": "npx tsx scripts/audit-continuity.ts",
    "audit:memory": "npx tsx scripts/audit-memory.ts",
    "audit:persistence": "npx tsx scripts/audit-persistence.ts",
    "verify:040d": "npx tsx scripts/verify-040d-persistence.ts",
    "verify:040d5": "npx tsx scripts/verify-040d5.ts",
    "verify:040c": "npx tsx scripts/verify-040c.ts",
    "audit:identity-sync": "npx tsx scripts/audit-identity-sync.ts",
    "audit:atlas-aware-ai": "npx tsx scripts/audit-atlas-aware-ai.ts",
    "audit:universe": "npx tsx scripts/audit-universe.ts",
    "audit:artifacts": "npx tsx scripts/audit-artifacts.ts",
    "audit:bourbon-intelligence": "npx tsx scripts/audit-bourbon-intelligence.ts",
    "audit:bourbon-graph": "npx tsx scripts/audit-bourbon-graph.ts",
    "audit:graph": "npx tsx scripts/audit-graph.ts",
    "audit:graph-enrichment": "npx tsx scripts/audit-graph-enrichment.ts",
    "audit:weekly-engagement": "npx tsx scripts/audit-weekly-engagement.ts",
    "launch:domain": "node scripts/launch-domain.js",
    "end-of-pass": "powershell -ExecutionPolicy Bypass -File ./scripts/end-of-pass.ps1",
    "predev": "npm run setup && npm run enforce",
    "prebuild": "npm run setup && npm run enforce",
    "prelint": "npm run enforce",
    "pretypecheck": "npm run enforce",
    "preinstall": "node scripts/enforce-h-drive.js",
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "node scripts/typecheck-workspaces.js",
    "generate:app": "node packages/self-build/cli/generate.js",
    "build:catalog": "node scripts/build-catalog.js",
    "db:migrate": "npx supabase db push",
    "db:reset": "supabase db reset",
    "db:diagnose": "node scripts/db-diagnostics.js",
    "db:seed": "node scripts/seed-platform.js",
    "seed:community": "npx tsx scripts/seed-community.ts",
    "verify:revenue": "npx tsx scripts/verify-revenue.ts",
    "audit:revenue": "npx tsx scripts/verify-revenue.ts",
    "push:netlify-env": "powershell -ExecutionPolicy Bypass -File ./scripts/push-netlify-env.ps1 -TriggerDeploy"
  },
  "devDependencies": {
    "@supabase/supabase-js": "^2.49.0",
    "tsx": "^4.19.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "npm@10.9.0",
  "dependencies": {
    "foundryos": "file:"
  }
}
